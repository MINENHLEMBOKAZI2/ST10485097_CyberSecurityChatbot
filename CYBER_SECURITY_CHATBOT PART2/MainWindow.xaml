<Window x:Class="CYBER_SECURITY_CHATBOT_PART2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CYBER_SECURITY_CHATBOT_PART2"
        mc:Ignorable="d"
        Title="Cybersecurity Chatbot" Height="650" Width="450"
        WindowStartupLocation="CenterScreen" Background="#F4F6F9">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1E293B" Padding="15,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="35" Height="35" Background="#38BDF8" CornerRadius="17.5" Margin="0,0,10,0">
                    <TextBlock Text="🤖" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Cybersecurity Chatbot" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="10">
            <StackPanel x:Name="ChatHistoryPanel">

                <Grid Margin="0,5,0,10" HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="🤖" FontSize="20" VerticalAlignment="Top" Margin="0,5,0,0"/>
                    <Border Grid.Column="1" Background="White" CornerRadius="0,15,15,15" Padding="12,10" MaxWidth="300" BorderBrush="#E2E8F0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Cybersecurity Chatbot" FontSize="11" Foreground="#64748B" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="Hello! I am your Cybersecurity Assistant. Before we get started, what is your name?" TextWrapping="Wrap" Foreground="#334155" FontSize="13"/>
                        </StackPanel>
                    </Border>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="85"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="TxtUserInput" Grid.Column="0" 
                         Padding="10,0" VerticalContentAlignment="Center" 
                         FontSize="14" BorderBrush="#CBD5E1" BorderThickness="1"
                         GotFocus="TxtUserInput_GotFocus" LostFocus="TxtUserInput_LostFocus"
                         Text="Type your message here..." Foreground="#94A3B8">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="20"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <Button x:Name="BtnSend" Grid.Column="1" Content="SEND" 
                        Margin="10,0,0,0" Background="#1E293B" Foreground="White" 
                        FontWeight="Bold" FontSize="12" Click="BtnSend_Click" IsDefault="True">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="20"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>